#!/usr/bin/expect -f
set timeout -1

spawn ssh -o StrictHostKeyChecking=no euclidcam@192.168.1.12
expect "password:"
send "euclidcam\r"
expect "$ "

send "sudo apt-get update\r"
expect "$ "

send "sudo apt-get install -y python3-numpy python3-pil python3-libcamera\r"
expect "$ "

send "cd /opt/euclidcam/firmware\r"
expect "$ "

send "export DISPLAY=:0\r"
expect "$ "

send "python3 main.py &\r"
expect "$ "

send "exit\r"
expect eof
